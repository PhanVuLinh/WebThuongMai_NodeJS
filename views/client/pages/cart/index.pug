extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
  +alert-success(5000)
  +alert-error(5000)

  .container.my-4
    .row
      .col-12
        +box-head("Giỏ hàng của bạn")

    if(cartDetail.products.length > 0)

      .row.mt-4
        .col-12
          .table-responsive
            table.table.align-middle.table-hover.shadow-sm
              thead.table-light
                tr.text-right
                  th STT
                  th Ảnh
                  th Tên sản phẩm
                  th Giá
                  th Số lượng
                  th Tổng tiền
                  th Hành động
              tbody
                each item,index in cartDetail.products
                  tr.text-right
                    td.fw-semibold #{index + 1}

                    td
                      img.rounded.shadow-sm(
                        src=item.productInfo.thumbnail
                        alt=item.productInfo.title
                        width="70"
                      )

                    td.text-start
                      a.text-decoration-none.fw-semibold.text-dark(
                        href=`/products/detail/${item.productInfo.slug}`
                      )
                        | #{item.productInfo.title}

                    td.text-primary.fw-bold
                      | #{item.productInfo.priceNew.toLocaleString()}$

                    td
                      input.form-control.text-center.mx-auto(
                        type="number"
                        name="quantity"
                        value=item.quantity
                        min="1"
                        item-id=item.product_id
                        style="width: 70px"
                      )

                    td.text-danger.fw-bold
                      | #{item.totalPrice.toLocaleString()}$

                    td
                      a.btn.btn-sm.btn-outline-danger(
                        href=`/cart/delete/${item.product_id}`
                      )
                        i.bi.bi-trash3
                        |  Xóa

      // ===== Tổng tiền + Thanh toán =====
      .row.mt-4
        .col-12.text-end
          hr
          h4.fw-bold
            | Tổng đơn hàng:
            span.text-danger.ms-2
              | #{cartDetail.totalPrice.toLocaleString()}$

          a.btn.btn-success.btn-lg.mt-3.px-4(
            href="/checkout"
          )
            i.bi.bi-credit-card.me-2
            | Thanh toán

    else
      .row.mt-4
        .col-12.text-center.py-5
          i.bi.bi-cart-x.fs-1.text-muted
          h5.mt-3.text-muted Chưa có sản phẩm nào trong giỏ hàng
          a.btn.btn-primary.mt-3(href="/products")
            | Tiếp tục mua sắm