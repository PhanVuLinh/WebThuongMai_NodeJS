extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-error(5000)

  .container.my-5
    .row.justify-content-center
      .col-lg-6.col-md-8

        .card.shadow-lg.border-0.rounded-4
          .card-body.p-5

            h2.text-center.mb-4.fw-bold Đăng nhập tài khoản

            form(
              action="/user/login"
              method="POST"
            )

              .mb-3
                label.form-label(for="email") Email
                input.form-control.form-control-lg(
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Nhập email"
                  required
                )

              .mb-3.position-relative
                label.form-label(for="password") Mật khẩu
                input.form-control.form-control-lg(
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Nhập mật khẩu"
                  required
                )


              .d-flex.justify-content-between.align-items-center.mb-4
                .form-check
                  input.form-check-input(
                    type="checkbox"
                    id="remember"
                  )
                  label.form-check-label(for="remember") Ghi nhớ đăng nhập

                a.text-decoration-none.small(href="/user/password/forgot") Quên mật khẩu?

              button.btn.btn-primary.btn-lg.w-100.rounded-3(
                type="submit"
              ) Đăng nhập

            .text-center.mt-4
              span Chưa có tài khoản?
              a.text-decoration-none.fw-semibold.ms-1(
                href="/user/register"
              ) Đăng ký ngay