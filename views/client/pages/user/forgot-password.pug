extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-error(5000)

  .container.my-5
    .row.justify-content-center
      .col-lg-6.col-md-8

        .card.shadow-lg.border-0.rounded-4
          .card-body.p-5

            h2.text-center.fw-bold.mb-3 Quên mật khẩu
            p.text-center.text-muted.mb-4
              | Nhập email của bạn để nhận liên kết đặt lại mật khẩu

            form(
              action="/user/password/forgot"
              method="POST"
            )

              .mb-4
                label.form-label(for="email") Email
                .input-group
                  span.input-group-text
                    i.bi.bi-envelope
                  input.form-control.form-control-lg(
                    type="email"
                    id="email"
                    name="email"
                    placeholder="Nhập email của bạn"
                  )

              button.btn.btn-primary.btn-lg.w-100.rounded-3(
                type="submit"
              ) Gửi mail xác nhận

            .text-center.mt-4
              a.text-decoration-none.fw-semibold(
                href="/user/login"
              ) ← Quay lại đăng nhập