extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-error(5000)

  .container.py-5
    .row.justify-content-center
      .col-lg-5.col-md-7.col-12
        .card.shadow-lg.border-0.rounded-4
          .card-body.p-4.p-md-5

            .text-center.mb-4
              h2.fw-bold.mb-2 Đổi mật khẩu
              p.text-muted.mb-0 Vui lòng nhập mật khẩu mới của bạn

            form(
              action="/user/password/reset"
              method="POST"
            )

              .mb-3
                label.form-label.fw-semibold(for="password") Mật khẩu mới
                input.form-control.form-control-lg.rounded-3(
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Nhập mật khẩu mới"
                  
                )

              .mb-4
                label.form-label.fw-semibold(for="confirmPassword") Xác nhận mật khẩu
                input.form-control.form-control-lg.rounded-3(
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  placeholder="Nhập lại mật khẩu"
                  
                )

              button.btn.btn-primary.btn-lg.w-100.rounded-3.shadow-sm(
                type="submit"
              ) Đổi mật khẩu