extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-error(5000)

  .container.my-5
    .row.justify-content-center
      .col-lg-6.col-md-8

        .card.shadow-lg.border-0.rounded-4
          .card-body.p-5

            h2.text-center.mb-4.fw-bold Đăng ký tài khoản

            form(
              action="/user/register"
              method="POST"
            )

              .mb-3
                label.form-label(for="fullName") Họ và tên
                input.form-control.form-control-lg(
                  type="text"
                  id="fullName"
                  name="fullName"
                  placeholder="Nhập họ và tên"
                  
                )

              .mb-3
                label.form-label(for="email") Email
                input.form-control.form-control-lg(
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Nhập email"
                  
                )

              .mb-3
                label.form-label(for="password") Mật khẩu
                input.form-control.form-control-lg(
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Nhập mật khẩu"
                  
                )

              button.btn.btn-primary.btn-lg.w-100.rounded-3(
                type="submit"
              ) Đăng ký

            .text-center.mt-4
              span Đã có tài khoản? 
              a.text-decoration-none.fw-semibold(href="/user/login") Đăng nhập ngay