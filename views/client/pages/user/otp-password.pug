extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-error(5000)

  .container.d-flex.align-items-center.justify-content-center(style="min-height: 80vh;")
    .col-md-6.col-lg-5
      .card.shadow-lg.border-0.rounded-4
        .card-body.p-4

          h3.text-center.fw-bold.mb-4.text-primary
            i.bi.bi-shield-lock.me-2
            | Nhập mã OTP xác thực

          form(action="/user/password/otp" method="POST")

            .mb-3
              label.form-label.fw-semibold(for="email") Email
              input.form-control.form-control-lg(
                type="email"
                id="email"
                name="email"
                required
                value=email
                readonly
              )

            .mb-4
              label.form-label.fw-semibold(for="otp") Mã OTP
              input.form-control.form-control-lg.text-center(
                type="text"
                id="otp"
                name="otp"
                maxlength="6"
                placeholder="Nhập 6 số OTP"
                required
              )

            button.btn.btn-primary.w-100.btn-lg.rounded-pill.shadow-sm(type="submit")
              i.bi.bi-check-circle.me-2
              | Xác nhận