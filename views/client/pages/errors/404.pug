doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title 404 Not Found

    // Bootstrap 5
    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.
      body {
        margin: 0;
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        font-family: 'Segoe UI', sans-serif;
      }

      .wrapper {
        min-height: 100vh;
      }

      .error-box {
        background: #ffffff;
        padding: 60px 50px;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        text-align: center;
        max-width: 500px;
        width: 100%;
      }

      .error-code {
        font-size: 110px;
        font-weight: 800;
        color: #4e73df;
        margin-bottom: 10px;
      }

      .error-text {
        font-size: 18px;
        color: #6c757d;
        margin-bottom: 30px;
      }

      .btn-modern {
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease;
      }

      .btn-modern:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      }

  body
    .container.wrapper.d-flex.justify-content-center.align-items-center
      .error-box

        h1.error-code 404

        h3.mb-3 404 Not Found

        p.error-text
        |  Trang bạn đang tìm không tồn tại hoặc đã bị xóa.

        button.btn.btn-primary.btn-modern(
          onclick="history.back()"
        ) ← Trở lại