extends  ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
block main 
  h1.mb-3 Trang danh sách sản phẩm

  .card.mb-3
    .card-header Bộ lọc và Tìm kiếm
    .card-body
      .row
        .col-6
          +filter-status(filterStatus)
        .col-6
          +search(keyword)
  .card.mb-3
    .card-header Danh sách sản phẩm
    .card-body
      table.table.table-hover.table-sm.align-middle
        thead
          tr
            th STT
            th Hình ảnh
            th Tiêu đề
            th Giá
            th Trạng thái
            th Hành động
        tbody
          each item, index in products
            tr
              td #{index + 1}
              td
                img.rounded(
                  src= item.thumbnail
                  alt= item.title
                  width="80"
                )
              td #{item.title}
              td
                strong #{item.price}
              td
                if(item.status == "active")
                  span.badge.bg-success.rounded-pill Hoạt động
                else 
                  span.badge.bg-danger.rounded-pill Dừng hoạt động
              td
                button.btn.btn-warning.btn-sm Sửa
                button.btn.btn-danger.btn-sm.ms-1 Xóa

  nav(aria-label="Page navigation")
    ul.pagination.justify-content-center
      if(pagination.currentPage > 1)
        li.page-item
          button(
            class="page-link"
            button-pagination = pagination.currentPage - 1
          ) Trang trước
      - for (var i = 1; i<= pagination.totalPage; i++)
          li(class = `page-item ${pagination.currentPage == i ?"active":""}`)
            button(
              class="page-link"
              button-pagination = i
            ) #{i}
      if(pagination.currentPage < pagination.totalPage)
        li.page-item
          button(
            class="page-link"
            button-pagination = pagination.currentPage + 1
          ) Trang sau
      
      div.ms-4 
        li.page-item
          button(
            class="page-link"
            button-pagination = pagination.currentPage =1
          ) Trang đầu

      div.ms-4 
        li.page-item
          button(
            class="page-link"
            button-pagination = pagination.totalPage
          ) Trang cuối
        