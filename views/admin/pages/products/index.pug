extends  ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
block main 
  h1.mb-3 Trang danh sách sản phẩm

  .card.mb-3
    .card-header Bộ lọc và Tìm kiếm
    .card-body
      .row
        .col-6
          +filter-status(filterStatus)
        .col-6
          +search(keyword)
  .card.mb-3
    .card-header Danh sách sản phẩm
    .card-body
      form(
        action=`${prefixAdmin}/products/change-multi?_method=PATCH`
        method="POST"
        form-change-multi
      )
        .d-flex.align-items-start
          .form-group
            select.form-select(name="type" )
              option(value="active") Hoạt động
              option(value="inactive") Dừng hoạt động

          .form-group
            input.form-control.d-none(
              type="text"
              name="ids"
              value=""
            )
          button.btn.btn-primary(type="submit") Áp dụng

      table(
        class="table table-hover table-sm align-middle" 
        checkbox-multi
      )
        thead
          tr
            th 
              input(type="checkbox" name="checkall")
            th STT
            th Hình ảnh
            th Tiêu đề
            th Giá
            th Trạng thái
            th Hành động
        tbody
          each item, index in products
            tr
              td 
                input(
                  type="checkbox"
                  name="id"
                  value=item.id
                )
              td #{index + 1}
              td
                img.rounded(
                  src= item.thumbnail
                  alt= item.title
                  width="80"
                )
              td #{item.title}
              td
                strong #{item.price}
              td
                if(item.status == "active")
                  button(
                    data-status=item.status
                    data-id = item.id 
                    button-change-status
                    class = "badge bg-success rounded-pill"
                  ) Hoạt động
                else 
                  button(
                    data-status=item.status
                    data-id = item.id
                    button-change-status
                    class = "badge bg-danger rounded-pill "
                  ) Dừng hoạt động
              td
                button.btn.btn-warning.btn-sm Sửa
                button.btn.btn-danger.btn-sm.ms-1 Xóa

  +pagination(pagination)

  form(
    action=""
    method="POST"
    id="form-change-status"
    data-path=`${prefixAdmin}/products/change-status`
  )


  script(src="/admin/js/products.js") 
        