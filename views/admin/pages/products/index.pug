extends  ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
include ../../mixins/sort.pug
include ../../mixins/moment.pug

block main 
  if(role.permissions.includes("products_view"))

    +alert-success(5000)
    +alert-error(5000)

    .d-flex.justify-content-between.align-items-center.mb-4
      h2.fw-bold.text-primary 
        i.fa-solid.fa-box-open.me-2
        | Danh sách sản phẩm

      if(role.permissions.includes("products_create"))
        a.btn.btn-success.shadow-sm(
          href=`${prefixAdmin}/products/create`
        )
          i.fa-solid.fa-plus.me-1
          | Thêm sản phẩm

    // FILTER
    .card.shadow-sm.border-0.mb-4
      .card-header.bg-light.fw-bold
        i.fa-solid.fa-filter.me-2
        | Bộ lọc & Tìm kiếm
      .card-body
        .row.g-3
          .col-md-6
            +filter-status(filterStatus)
          .col-md-6
            +search(keyword)

    // SORT
    .card.shadow-sm.border-0.mb-4
      .card-header.bg-light.fw-bold
        i.fa-solid.fa-sort.me-2
        | Sắp xếp
      .card-body
        .row
          .col-md-4
            +sort()

    // PRODUCT TABLE
    .card.shadow-sm.border-0
      .card-header.bg-white.fw-bold
        i.fa-solid.fa-table.me-2
        | Danh sách sản phẩm

      .card-body

        .row.mb-3
          .col-md-8
            +form-change-multi(`${prefixAdmin}/products/change-multi?_method=PATCH`, true)

        table.table.table-hover.align-middle
          thead.table-light
            tr
              th
                input(type="checkbox" name="checkall")
              th STT
              th Hình ảnh
              th Tiêu đề
              th Giá
              th Vị trí
              th Trạng thái
              th Người tạo
              th Cập nhật
              th.text-center Hành động

          tbody
            each item, index in products
              tr

                td
                  input(
                    type="checkbox"
                    name="id"
                    value=item.id
                  )

                td.fw-bold  #{pagination.limitItem*(pagination.currentPage - 1) + (index + 1)}

                td
                  img.rounded.shadow-sm(
                    src=item.thumbnail
                    alt=item.title
                    width="60"
                  )

                td.fw-semibold
                  | #{item.title}

                td.text-danger.fw-bold
                  | #{item.price}

                td
                  input.form-control.form-control-sm(
                    type="number"
                    value=item.position
                    min="1"
                    name="position"
                    style="width:70px"
                  )

                td
                  if(role.permissions.includes("products_edit"))

                    if(item.status == "active")
                      button.badge.status-active(
                        data-status=item.status
                        data-id=item.id
                        button-change-status
                      ) Hoạt động

                    else
                      button.badge.status-stop(
                        data-status=item.status
                        data-id=item.id
                        button-change-status
                      ) Dừng

                  else

                    if(item.status == "active")
                      span.badge.bg-success Hoạt động
                    else
                      span.badge.bg-secondary Dừng

                td.small
                  div #{item.accountFullName}
                  +formatDate(item.createdBy.createAt)

                td.small
                  - const updatedBy = item.updatedBy.slice(-1)[0]
                  if(updatedBy)
                    div #{updatedBy.accountFullName}
                    +formatDateTime(updatedBy.updatedAt)

                td.text-center

                  a.btn.btn-sm.btn-primary.me-1(
                    href=`${prefixAdmin}/products/detail/${item.id}`
                  )
                    i.fa-solid.fa-eye

                  if(role.permissions.includes("products_edit"))
                    a.btn.btn-sm.btn-warning.me-1(
                      href=`${prefixAdmin}/products/edit/${item.id}`
                    )
                      i.fa-solid.fa-pen

                  if(role.permissions.includes("products_delete"))
                    button.btn.btn-sm.btn-danger(
                      button-delete
                      data-id=item.id
                    )
                      i.fa-solid.fa-trash

    .mt-3
      +pagination(pagination)

    form(
      action=""
      method="POST"
      id="form-change-status"
      data-path=`${prefixAdmin}/products/change-status`
    )

    form(
      action=""
      method="POST"
      id="form-delete-item"
      data-path=`${prefixAdmin}/products/delete`
    )

    script(src="/admin/js/products.js")