extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  if(role.permissions.includes("accounts_edit"))

    .d-flex.justify-content-between.align-items-center.mb-4
      h2.fw-bold.text-warning
        i.fa-solid.fa-user-pen.me-2
        | Chỉnh sửa tài khoản

    +alert-error(5000)
    +alert-success(5000)

    if(roles)

      .card.shadow-sm.border-0
        .card-body

          form(
            action=`${prefixAdmin}/accounts/edit/${data.id}?_method=PATCH`
            method="POST"
            enctype="multipart/form-data"
          )

            .row

              // LEFT
              .col-md-8

                // Họ tên
                .mb-3
                  label.form-label(for="fullName") Họ tên *
                  input.form-control(
                    type="text"
                    id="fullName"
                    name="fullName"
                    required
                    value=data.fullName
                  )

                // Email
                .mb-3
                  label.form-label(for="email") Email *
                  input.form-control(
                    type="email"
                    id="email"
                    name="email"
                    required
                    value=data.email
                  )

                // Mật khẩu
                .mb-3
                  label.form-label(for="password") Mật khẩu mới
                  input.form-control(
                    type="password"
                    id="password"
                    name="password"
                  )
                  small.text-muted Để trống nếu không muốn thay đổi

                // Số điện thoại
                .mb-3
                  label.form-label(for="phone") Số điện thoại
                  input.form-control(
                    type="text"
                    id="phone"
                    name="phone"
                    value=data.phone
                  )

                // Phân quyền
                .mb-3
                  label.form-label(for="role_id") Phân quyền
                  select.form-select(
                    name="role_id"
                    id="role_id"
                  )
                    option(disabled selected) -- Chọn --
                    each item in roles
                      option(
                        value=item._id
                        selected=(item.id == data.role_id ? true : false)
                      ) #{item.title}

                // Trạng thái
                .mb-3
                  label.form-label Trạng thái
                  br

                  .form-check.form-check-inline
                    input.form-check-input(
                      type="radio"
                      id="statusActive"
                      name="status"
                      value="active"
                      checked=(data.status=="active" ? true : false)
                    )
                    label.form-check-label(for="statusActive") Hoạt động

                  .form-check.form-check-inline
                    input.form-check-input(
                      type="radio"
                      id="statusInActive"
                      name="status"
                      value="inactive"
                      checked=(data.status=="inactive" ? true : false)
                    )
                    label.form-check-label(for="statusInActive") Dừng hoạt động


              // RIGHT (Avatar)
              .col-md-4

                .mb-3(upload-image)
                  label.form-label(for="avatar") Ảnh đại diện

                  input.form-control(
                    type="file"
                    id="avatar"
                    name="avatar"
                    accept="image/*"
                    upload-image-input
                  )

                  img.mt-3.rounded.shadow-sm(
                    src=data.avatar
                    width="120"
                    height="120"
                    style="object-fit:cover"
                    class="image-preview"
                    upload-image-preview
                  )

            hr

            button.btn.btn-warning.px-4(
              type="submit"
            )
              i.fa-solid.fa-save.me-1
              | Cập nhật tài khoản

    else
      .alert.alert-warning
        p.mb-2
          i.fa-solid.fa-circle-exclamation.me-2
          | Vui lòng tạo nhóm quyền trước khi cập nhật

        a.btn.btn-secondary(
          href=`${prefixAdmin}/roles/create`
        )
          i.fa-solid.fa-plus.me-1
          | Tạo nhóm quyền