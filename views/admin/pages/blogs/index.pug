extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main

  +alert-success(5000)
  +alert-error(5000)
  .container-fluid

    h3.fw-bold.mb-4
      i.fas.fa-newspaper.me-2.text-primary
      | Quản lý bài viết

    .card.admin-card
      .card-body

        .row.mb-3
          .col-6
          .col-6.text-end
            a.btn.btn-success(
              href=`${prefixAdmin}/blogs/create`
            )
              i.fa-solid.fa-plus
              |  Thêm bài viết

        table.table.table-hover.align-middle
          thead.table-light
            tr
              th
                input(type="checkbox" name="checkall")
              th STT
              th Ảnh
              th Tiêu đề
              th Vị trí
              th Trạng thái
              th Hành động

          tbody
            if(blog.length > 0)
              each item, index in blog
                tr
                  td
                    input(
                      type="checkbox"
                      name="id"
                      value=item.id
                    )

                  td #{index + 1}

                  td
                    img.rounded.shadow-sm(
                      src=item.thumbnail
                      alt=item.title
                      width="80"
                      height="80"
                      style="object-fit:cover"
                    )

                  td.fw-semibold #{item.title}

                  td
                    input.form-control.form-control-sm(
                      type="number"
                      value=item.position
                      min="1"
                      name="position"
                      style="width:70px"
                    )

                  td
                    if(item.status == "active")
                      button.badge.status-active(
                        type="button"
                        data-status=item.status
                        data-id=item.id
                        button-change-status
                      ) Hoạt động

                    else
                      button.badge.status-stop(
                        type="button"
                        data-status=item.status
                        data-id=item.id
                        button-change-status
                      ) Dừng


                  td.action-buttons

                    a.btn.btn-sm.btn-primary.me-1(
                      href=`${prefixAdmin}/blogs/detail/${item.id}`
                    )
                      i.fa-solid.fa-eye

                    a.btn.btn-sm.btn-warning.me-1(
                      href=`${prefixAdmin}/blogs/edit/${item.id}`
                    )
                      i.fa-solid.fa-pen

                    button.btn.btn-sm.btn-danger(
                      button-delete
                      data-id=item.id
                    )
                      i.fa-solid.fa-trash

            else
              tr
                td(colspan="7" class="text-center")
                  | Chưa có bài viết nào

    form(
      action=""
      method="POST"
      id="form-change-status"
      data-path=`${prefixAdmin}/blogs/change-status`
    )
    form(
      action=""
      method="POST"
      id="form-delete-item"
      data-path=`${prefixAdmin}/blogs/delete`
    )

    script(src="/admin/js/products.js")