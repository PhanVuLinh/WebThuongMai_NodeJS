extends ../../layouts/auth.pug
include ../../mixins/alert.pug

block main
  .container-fluid
    .row.min-vh-100.justify-content-center.align-items-center
      .col-11.col-sm-8.col-md-6.col-lg-4
        .card.shadow-lg.border-0.rounded-4
          .card-body.p-5
            h3.text-center.mb-4.fw-bold.text-primary Đăng nhập hệ thống

            +alert-error(5000)

            form(
              action=`${prefixAdmin}/auth/login`
              method="POST"
            )
              .mb-3
                label.form-label(for="email") Email
                input.form-control.form-control-lg(
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Nhập email..."
                )

              .mb-4
                label.form-label(for="password") Mật khẩu
                input.form-control.form-control-lg(
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Nhập mật khẩu..."
                )

              button.btn.btn-primary.btn-lg.w-100(type="submit")
                i.bi.bi-box-arrow-in-right.me-2
                | Đăng nhập
