extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  if(role.permissions.includes("roles_permissions"))

    .d-flex.justify-content-between.align-items-center.mb-4
      h3.fw-bold.text-dark
        i.fa-solid.fa-shield-halved.me-2.text-primary
        | Quản lý phân quyền

      button.btn.btn-primary.shadow-sm(
        type="submit"
        button-submit
      )
        i.fa-solid.fa-floppy-disk.me-1
        | Lưu phân quyền

    +alert-error(5000)
    +alert-success(5000)

    if(records)

      .card.shadow.border-0.rounded-3

        .card-body.p-0

          div(data-records=records)

          .table-responsive

            table.table.align-middle.table-hover.mb-0(
              table-permissions
            )

              thead.bg-light
                tr
                  th.ps-4(style="width:250px") Tính năng
                  each item in records
                    th.text-center
                      span.badge.bg-primary #{item.title}

              tbody

                tr(data-name="id" class="d-none")
                  td
                  each item in records
                    td.text-center
                      input(type="text" value=item.id)

                // Tổng quan
                tr.section-title
                  td(colspan="100%")
                    i.fa-solid.fa-user-shield.me-2
                    | Tổng quan

                tr(data-name="dashboard_view")
                  td.ps-4 Xem
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")


                // Danh mục sản phẩm
                tr.section-title
                  td(colspan="100%")
                    i.fa-solid.fa-folder-open.me-2
                    | Danh mục sản phẩm

                tr(data-name="products-category_view")
                  td.ps-4 Xem
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="products-category_create")
                  td.ps-4 Thêm mới
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="products-category_edit")
                  td.ps-4 Chỉnh sửa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="products-category_delete")
                  td.ps-4 Xóa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")


                // Sản phẩm
                tr.section-title
                  td(colspan="100%")
                    i.fa-solid.fa-box.me-2
                    | Sản phẩm

                tr(data-name="products_view")
                  td.ps-4 Xem
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="products_create")
                  td.ps-4 Thêm mới
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="products_edit")
                  td.ps-4 Chỉnh sửa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="products_delete")
                  td.ps-4 Xóa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")


                // Tài khoản
                tr.section-title
                  td(colspan="100%")
                    i.fa-solid.fa-user-shield.me-2
                    | Tài khoản

                tr(data-name="accounts_view")
                  td.ps-4 Xem
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="accounts_create")
                  td.ps-4 Thêm mới
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="accounts_edit")
                  td.ps-4 Chỉnh sửa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="accounts_delete")
                  td.ps-4 Xóa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                //Quản lý đơn hàng
                tr.section-title
                  td(colspan="100%")
                    i.fa-solid.fa-user-shield.me-2
                    | Quản lý đơn hàng

                tr(data-name="orders_view")
                  td.ps-4 Xem
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")
                    
                tr(data-name="orders_delete")
                  td.ps-4 Xóa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                // Nhóm quyền
                tr.section-title
                  td(colspan="100%")
                    i.fa-solid.fa-users-gear.me-2
                    | Nhóm quyền

                tr(data-name="roles_view")
                  td.ps-4 Xem
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="roles_create")
                  td.ps-4 Thêm mới
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="roles_edit")
                  td.ps-4 Chỉnh sửa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="roles_delete")
                  td.ps-4 Xóa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="roles_permissions")
                  td.ps-4 Phân quyền
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")


                // Cài đặt chung
                tr.section-title
                  td(colspan="100%")
                    i.fa-solid.fa-user-shield.me-2
                    | Cài đặt chung

                tr(data-name="settings_view")
                  td.ps-4 Xem
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

                tr(data-name="settings_edit")
                  td.ps-4 Chỉnh sửa
                  each item in records
                    td.text-center
                      input.permission(type="checkbox")

    form(
      id="form-change-permissions"
      method="POST"
      action=`${prefixAdmin}/roles/permissions?_method=PATCH`
    )
      .d-none
        input(
          type="text"
          name="permissions"
        )

    script(src="/admin/js/roles.js")