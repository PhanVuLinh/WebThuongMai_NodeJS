extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  if(role.permissions.includes("roles_edit"))

    .d-flex.align-items-center.mb-4
      h2.fw-bold.text-warning
        i.fa-solid.fa-user-gear.me-2
        | Chỉnh sửa nhóm quyền

    +alert-error(5000)
    +alert-success(5000)

    .row.justify-content-center
      .col-lg-6

        .card.shadow-sm.border-0
          .card-body.p-4

            form(
              action=`${prefixAdmin}/roles/edit/${data._id}?_method=PATCH`
              method="POST"
            )

              .mb-4
                label.form-label.fw-semibold(for="title") Tiêu đề
                input.form-control(
                  type="text"
                  id="title"
                  name="title"
                  required
                  value=data.title
                  placeholder="Nhập tên nhóm quyền..."
                )

              .mb-4
                label.form-label.fw-semibold(for="desc") Mô tả
                input.form-control(
                  type="text"
                  id="desc"
                  name="description"
                  value=data.description
                  placeholder="Mô tả ngắn về nhóm quyền..."
                )

              .d-flex.justify-content-between

                a.btn.btn-secondary(
                  href=`${prefixAdmin}/roles`
                )
                  i.fa-solid.fa-arrow-left.me-1
                  | Quay lại

                button.btn.btn-warning(
                  type="submit"
                )
                  i.fa-solid.fa-save.me-1
                  | Cập nhật