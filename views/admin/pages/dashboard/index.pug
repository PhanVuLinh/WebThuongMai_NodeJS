extends ../../layouts/default.pug

block main
  if(role.permissions.includes("dashboard_view"))
    .d-flex.align-items-center.justify-content-between.mb-4
      h3.fw-bold.text-dark
        i.fas.fa-chart-line.me-2.text-primary
        | Trang tổng quan

    // ===== STATISTICS =====
    .row.g-4

      .col-xl-3.col-md-6
        .stat-card
          .icon.bg-primary
            i.fas.fa-list
          .info
            span.title Danh mục sản phẩm
            h2 #{statistic.categoryProduct.total}
            p.mb-0
              span.text-success.fw-semibold #{statistic.categoryProduct.active} hoạt động
              |  /
              span.text-danger.fw-semibold #{statistic.categoryProduct.inactive} dừng

      .col-xl-3.col-md-6
        .stat-card
          .icon.bg-success
            i.fas.fa-box
          .info
            span.title Sản phẩm
            h2 #{statistic.product.total}
            p.mb-0
              span.text-success.fw-semibold #{statistic.product.active} hoạt động
              |  /
              span.text-danger.fw-semibold #{statistic.product.inactive} dừng

      .col-xl-3.col-md-6
        .stat-card
          .icon.bg-warning
            i.fas.fa-user-shield
          .info
            span.title Admin
            h2 #{statistic.account.total}
            p.mb-0
              span.text-success.fw-semibold #{statistic.account.active} hoạt động
              |  /
              span.text-danger.fw-semibold #{statistic.account.inactive} dừng

      .col-xl-3.col-md-6
        .stat-card
          .icon.bg-info
            i.fas.fa-users
          .info
            span.title Client
            h2 #{statistic.user.total}
            p.mb-0
              span.text-success.fw-semibold #{statistic.user.active} hoạt động
              |  /
              span.text-danger.fw-semibold #{statistic.user.inactive} dừng


    // ===== PROFILE =====
    .row.mt-5
      .col-lg-4

        .profile-card.text-center

          if(user.avatar)
            img.avatar(src=user.avatar)

          h4.mt-3.mb-1 #{user.fullName}

          if(role.title)
            span.badge.bg-primary.mb-3 #{role.title}

          .text-start.mt-3

            if(user.email)
              p.mb-2
                i.fas.fa-envelope.me-2.text-muted
                | #{user.email}

            if(user.phone)
              p.mb-0
                i.fas.fa-phone.me-2.text-muted
                | #{user.phone}