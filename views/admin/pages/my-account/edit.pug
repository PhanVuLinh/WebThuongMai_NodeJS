extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  .container.py-4
    .row.justify-content-center
      .col-lg-7

        .card.border-0.shadow.rounded-4
          .card-body.p-4

            h3.text-center.fw-bold.mb-4
              i.fas.fa-user-edit.me-2.text-primary
              | Cập nhật thông tin cá nhân

            +alert-success(5000)
            +alert-error(5000)

            form(
              action=`${prefixAdmin}/my-account/edit?_method=PATCH`
              method="POST"
              enctype="multipart/form-data"
            )

              // Họ tên
              .mb-3
                label.form-label.fw-semibold(for="fullName")
                  i.fas.fa-user.me-1
                  | Họ tên *
                input.form-control(
                  type="text"
                  id="fullName"
                  name="fullName"
                  required
                  value=user.fullName
                )

              // Email
              .mb-3
                label.form-label.fw-semibold(for="email")
                  i.fas.fa-envelope.me-1
                  | Email *
                input.form-control(
                  type="email"
                  id="email"
                  name="email"
                  required
                  value=user.email
                )

              // Mật khẩu
              .mb-3
                label.form-label.fw-semibold(for="password")
                  i.fas.fa-lock.me-1
                  | Mật khẩu mới
                input.form-control(
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Nhập nếu muốn thay đổi"
                )

              // Số điện thoại
              .mb-3
                label.form-label.fw-semibold(for="phone")
                  i.fas.fa-phone.me-1
                  | Số điện thoại
                input.form-control(
                  type="text"
                  id="phone"
                  name="phone"
                  value=user.phone
                )

              // Avatar
              .mb-4(upload-image)
                label.form-label.fw-semibold
                  i.fas.fa-image.me-1
                  | Avatar

                input.form-control(
                  type="file"
                  id="avatar"
                  name="avatar"
                  accept="image/*"
                  upload-image-input
                )

                .mt-3.text-center
                  img.image-preview.rounded-circle.shadow(
                    src=user.avatar
                    upload-image-preview
                  )

              .d-grid
                button.btn.btn-primary.btn-lg.rounded-pill(type="submit")
                  i.fas.fa-save.me-2
                  | Cập nhật