extends  ../../layouts/default.pug

block main 
  h1.mb-3 Danh mục sản phẩm

  .card.mb-3
    .card-header Danh sách 
    .card-body
      .row
        .col-8 
        .col-4 
          a(
            href=`${prefixAdmin}/products-category/create`
            class="btn btn-outline-success"
          ) + Thêm mới
      
      table(
        class="table table-hover table-sm align-middle" 
        checkbox-multi
      )
        thead
          tr
            th 
              input(type="checkbox" name="checkall")
            th STT
            th Hình ảnh
            th Tiêu đề
            th Vị trí
            th Trạng thái
            th Hành động
        tbody
          each item, index in records
            tr
              td 
                input(
                  type="checkbox"
                  name="id"
                  value=item.id
                )
              td #{index + 1}
              td
                img.rounded(
                  src= item.thumbnail
                  alt= item.title
                  width="80"
                )
              td #{item.title}
              td
                input(
                  type="number"
                  value= item.position
                  style="width: 60px"
                  min="1"
                  name="position"
                )
              td
                if(item.status == "active")
                  button(
                    data-status=item.status
                    data-id = item.id 
                    button-change-status
                    class = "badge bg-success rounded-pill"
                  ) Hoạt động
                else 
                  button(
                    data-status=item.status
                    data-id = item.id
                    button-change-status
                    class = "badge bg-danger rounded-pill "
                  ) Dừng hoạt động
              td
                a(
                  href=`${prefixAdmin}/products-category/detail/${item.id}`
                  class= "btn btn-primary btn-sm ms-1"
                ) Chi tiết

                a(
                  href=`${prefixAdmin}/products-category/${item.id}`
                  class= "btn btn-warning btn-sm ms-1"
                ) Sửa

                button.btn.btn-danger.btn-sm.ms-1(
                  button-delete
                  data-id = item.id
                )  Xóa