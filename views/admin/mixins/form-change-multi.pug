mixin form-change-multi (path, showPosition = true) 
  form(
        action=path
        method="POST"
        form-change-multi
      )
        .d-flex.align-items-start
          .form-group
            select.form-select(name="type" )
              option(disabled selected) --Chọn hành động--
              option(value="active") Hoạt động
              option(value="inactive") Dừng hoạt động
              option(value="delete-all") Xóa tất cả
              if showPosition
                option(value="change-position") Cập nhật vị trí
          .form-group
            input.form-control.d-none(
              type="text"
              name="ids"
              value=""
            )
          button.btn.btn-primary(type="submit") Áp dụng